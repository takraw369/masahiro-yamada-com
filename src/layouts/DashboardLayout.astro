---
export interface Props {
  title: string;
  fullHeight?: boolean;
}
const { title, fullHeight = false } = Astro.props;
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/dashboard', label: 'Dashboard', icon: '📊', exact: true },
  { href: '/dashboard/post', label: 'X Post', icon: '𝕏', exact: false },
  { href: '/dashboard/lian', label: 'リアン', icon: '💚', exact: false },
  { href: '/dashboard/schedule', label: 'Schedule', icon: '📅', exact: false },
  { href: '/dashboard/quest', label: 'Quest', icon: '⚔️', exact: false },
  { href: '/dashboard/treasury', label: 'Treasury', icon: '💰', exact: false },
  { href: '/dashboard/wishlist', label: 'Wish List', icon: '🎁', exact: false },
];

function isActive(item: { href: string; exact: boolean }): boolean {
  if (item.exact) return pathname === item.href;
  return pathname.startsWith(item.href);
}
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — ACE Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Zen+Kaku+Gothic+New:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-void:        #0D0B08;
      --bg-surface:     #1A1612;
      --bg-elevated:    #241F1A;
      --gold-pure:      #C9A96E;
      --gold-muted:     #8B7355;
      --gold-dim:       #5A4D3A;
      --gold-glow:      rgba(201,169,110,0.08);
      --text-primary:   #D4C5A9;
      --text-muted:     #7A6F5F;
      --text-dim:       #4A4030;
      --border-default: #2E2822;
      --border-hover:   #8B7355;
      --border-accent:  rgba(201,169,110,0.2);
      --sidebar-width:  240px;
    }

    html { font-size: 16px; }

    body {
      background: var(--bg-void);
      color: var(--text-primary);
      font-family: 'Zen Kaku Gothic New', sans-serif;
      font-weight: 300;
      min-height: 100vh;
      display: flex;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: var(--sidebar-width);
      flex-shrink: 0;
      background: var(--bg-surface);
      border-right: 1px solid var(--border-default);
      height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
      display: flex;
      flex-direction: column;
      z-index: 50;
      overflow-y: auto;
    }

    .sidebar-logo {
      padding: 28px 24px 24px;
      border-bottom: 1px solid var(--border-default);
    }

    .sidebar-logo-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 300;
      color: var(--gold-pure);
      line-height: 1;
      letter-spacing: 0.05em;
    }

    .sidebar-logo-sub {
      font-family: 'Zen Kaku Gothic New', sans-serif;
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-top: 4px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .sidebar-nav {
      flex: 1;
      padding: 16px 0;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 24px;
      color: var(--text-muted);
      text-decoration: none;
      font-family: 'Zen Kaku Gothic New', sans-serif;
      font-size: 0.875rem;
      font-weight: 400;
      transition: color 0.2s, background 0.2s, border-color 0.2s;
      border-left: 2px solid transparent;
      min-height: 44px;
    }

    .nav-item:hover {
      color: var(--text-primary);
      background: var(--gold-glow);
    }

    .nav-item.active {
      color: var(--gold-pure);
      border-left-color: var(--gold-pure);
      background: var(--gold-glow);
    }

    .nav-icon {
      font-size: 1rem;
      width: 20px;
      text-align: center;
      flex-shrink: 0;
    }

    .sidebar-footer {
      padding: 16px 24px;
      border-top: 1px solid var(--border-default);
    }

    .logout-link {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text-dim);
      text-decoration: none;
      font-size: 0.8rem;
      font-family: 'Zen Kaku Gothic New', sans-serif;
      padding: 10px 0;
      transition: color 0.2s;
      min-height: 44px;
    }

    .logout-link:hover {
      color: var(--text-muted);
    }

    /* ── Sidebar overlay (mobile) ── */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      z-index: 40;
    }

    .sidebar-overlay.visible {
      display: block;
    }

    /* ── Content area ── */
    .content-wrap {
      margin-left: var(--sidebar-width);
      flex: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Mobile top bar ── */
    .mobile-header {
      display: none;
      align-items: center;
      gap: 14px;
      padding: 14px 20px;
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border-default);
      position: sticky;
      top: 0;
      z-index: 30;
      min-height: 56px;
    }

    .hamburger {
      background: none;
      border: 1px solid var(--border-default);
      color: var(--text-muted);
      width: 40px;
      height: 40px;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      flex-shrink: 0;
      transition: border-color 0.2s;
    }

    .hamburger:hover {
      border-color: var(--border-hover);
    }

    .hamburger-bar {
      width: 18px;
      height: 1.5px;
      background: var(--text-muted);
    }

    .mobile-page-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 300;
      color: var(--gold-pure);
    }

    /* ── Main content ── */
    .main-content {
      flex: 1;
      padding: 32px 36px;
    }

    .main-content.full-height {
      padding: 0;
      overflow: hidden;
    }

    /* ── Mobile breakpoint ── */
    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
        transition: transform 0.3s ease;
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .content-wrap {
        margin-left: 0;
      }

      .mobile-header {
        display: flex;
      }

      .main-content {
        padding: 20px 16px;
      }

      .main-content.full-height {
        padding: 0;
      }
    }
  </style>
</head>
<body>
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div class="sidebar-logo-text">DASHBOARD</div>
      <div class="sidebar-logo-sub">ACE METHOD</div>
    </div>

    <nav class="sidebar-nav">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['nav-item', { active: isActive(item) }]}
        >
          <span class="nav-icon">{item.icon}</span>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="sidebar-footer">
      <a href="/dashboard/logout" class="logout-link">
        <span>⎋</span>
        <span>ログアウト</span>
      </a>
    </div>
  </aside>

  <div class="content-wrap">
    <div class="mobile-header">
      <button class="hamburger" id="hamburger" aria-label="メニューを開く">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
      <span class="mobile-page-title">{title}</span>
    </div>

    <main class:list={['main-content', { 'full-height': fullHeight }]}>
      <slot />
    </main>
  </div>

  <script>
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const hamburger = document.getElementById('hamburger');

    function openSidebar() {
      sidebar?.classList.add('open');
      overlay?.classList.add('visible');
    }

    function closeSidebar() {
      sidebar?.classList.remove('open');
      overlay?.classList.remove('visible');
    }

    hamburger?.addEventListener('click', openSidebar);
    overlay?.addEventListener('click', closeSidebar);
  </script>
</body>
</html>
