---
import ACECalendar from '../../components/dashboard/ACECalendar';
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ACE Dashboard — masahiro-yamada.com</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a1a;
      --surface: #12121f;
      --border: rgba(255,255,255,0.08);
      --accent: #F59E0B;
      --text: #e8e8f0;
      --text-dim: #7070a0;
    }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', 'Noto Sans JP', sans-serif;
      min-height: 100vh;
    }
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .header-logo {
      font-size: 1rem;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.2;
    }
    .header-logo span {
      font-size: 0.7rem;
      font-weight: 400;
      color: var(--text-dim);
      display: block;
    }
    .logout-link {
      color: var(--text-dim);
      text-decoration: none;
      font-size: 0.78rem;
      padding: 6px 12px;
      border: 1px solid var(--border);
      border-radius: 6px;
      transition: color 0.2s;
    }
    .logout-link:hover { color: var(--text); }
    main {
      padding: 20px;
      max-width: 480px;
      margin: 0 auto;
    }
  </style>
</head>
<body>
  <header>
    <div class="header-logo">
      ACE Dashboard
      <span>masahiro-yamada.com</span>
    </div>
    <a href="/dashboard/logout" class="logout-link">ログアウト</a>
  </header>
  <main>
    <ACECalendar client:load />
  </main>
</body>
</html>
