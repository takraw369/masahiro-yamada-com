---
import ACECalendar from '../../components/dashboard/ACECalendar';
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ACE Dashboard — masahiro-yamada.com</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a1a;
      --surface: #12121f;
      --border: rgba(255,255,255,0.08);
      --accent: #F59E0B;
      --text: #e8e8f0;
      --text-dim: #7070a0;
    }
    html { font-size: 18px; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', 'Noto Sans JP', sans-serif;
      min-height: 100vh;
    }
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 24px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .header-logo {
      font-size: 1.05rem;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.2;
    }
    .header-logo span {
      font-size: 0.72rem;
      font-weight: 400;
      color: var(--text-dim);
      display: block;
    }
    .logout-link {
      color: var(--text-dim);
      text-decoration: none;
      font-size: 0.82rem;
      padding: 7px 14px;
      border: 1px solid var(--border);
      border-radius: 6px;
      transition: color 0.2s;
    }
    .logout-link:hover { color: var(--text); }
    main {
      padding: 28px 24px;
      max-width: 900px;
      margin: 0 auto;
    }
    .nav-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
      margin-bottom: 28px;
    }
    .nav-card {
      display: flex;
      flex-direction: column;
      gap: 5px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px 18px;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.2s, background 0.2s;
    }
    .nav-card:hover {
      border-color: rgba(255,255,255,0.22);
      background: rgba(255,255,255,0.03);
    }
    .nav-card-icon { font-size: 1.5rem; }
    .nav-card-label { font-size: 0.95rem; font-weight: 700; margin-top: 2px; }
    .nav-card-desc { font-size: 0.78rem; color: var(--text-dim); }
  </style>
</head>
<body>
  <header>
    <div class="header-logo">
      ACE Dashboard
      <span>masahiro-yamada.com</span>
    </div>
    <a href="/dashboard/logout" class="logout-link">ログアウト</a>
  </header>
  <main>
    <div class="nav-grid">
      <a href="/dashboard/post" class="nav-card">
        <span class="nav-card-icon">𝕏</span>
        <span class="nav-card-label">X Post</span>
        <span class="nav-card-desc">投稿・アカウント管理</span>
      </a>
      <a href="/dashboard/lian" class="nav-card">
        <span class="nav-card-icon">💚</span>
        <span class="nav-card-label">リアン</span>
        <span class="nav-card-desc">LINE友だち管理</span>
      </a>
      <a href="/dashboard/cards" class="nav-card">
        <span class="nav-card-icon">🃏</span>
        <span class="nav-card-label">Flash Cards</span>
        <span class="nav-card-desc">ACE概念・復習・XP獲得</span>
      </a>
      <a href="/dashboard/schedule2" class="nav-card">
        <span class="nav-card-icon">📅</span>
        <span class="nav-card-label">Weekly Planner</span>
        <span class="nav-card-desc">週間カレンダー（新）</span>
      </a>
      <a href="/dashboard/schedule" class="nav-card">
        <span class="nav-card-icon">📤</span>
        <span class="nav-card-label">Schedule</span>
        <span class="nav-card-desc">X/LINE 投稿管理（旧）</span>
      </a>
      <a href="/dashboard/quest" class="nav-card">
        <span class="nav-card-icon">⚔️</span>
        <span class="nav-card-label">Quest</span>
        <span class="nav-card-desc">学習・習慣クエスト</span>
      </a>
    </div>
    <ACECalendar client:only="react" />
  </main>
</body>
</html>
