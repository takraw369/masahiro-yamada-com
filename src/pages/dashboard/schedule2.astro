---
import WeeklyPlanner from '../../components/dashboard/WeeklyPlanner';
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Weekly Planner — ACE Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg: #0a0a1a; --surface: #12121f; --border: rgba(255,255,255,0.08); --accent: #F59E0B; --text: #e8e8f0; --text-dim: #7070a0; }
    html { font-size: 18px; }
    body { background: var(--bg); color: var(--text); font-family: 'Inter','Noto Sans JP',sans-serif; min-height: 100vh; overflow: hidden; }
    header { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px; border-bottom: 1px solid var(--border); background: var(--surface); height: 58px; }
    .header-left { display: flex; align-items: center; gap: 14px; }
    .back-link { color: var(--text-dim); text-decoration: none; font-size: 0.88rem; }
    .back-link:hover { color: var(--text); }
    .header-logo { font-size: 1.05rem; font-weight: 800; color: var(--accent); }
    .header-logo span { font-size: 0.72rem; font-weight: 400; color: var(--text-dim); display: block; }
    .compare-link { font-size: 0.75rem; color: var(--text-dim); text-decoration: none; padding: 5px 10px; border: 1px solid var(--border); border-radius: 6px; }
    .compare-link:hover { color: var(--text); }
  </style>
</head>
<body>
  <header>
    <div class="header-left">
      <a href="/dashboard" class="back-link">← ダッシュボード</a>
      <div class="header-logo">Weekly Planner <span>masahiro-yamada.com · schedule2</span></div>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
      <a href="/dashboard/schedule" class="compare-link">← 旧 Schedule</a>
      <a href="/dashboard/logout" style="color:var(--text-dim);text-decoration:none;font-size:0.82rem;padding:7px 14px;border:1px solid var(--border);border-radius:6px;">ログアウト</a>
    </div>
  </header>
  <WeeklyPlanner client:only="react" />
</body>
</html>
