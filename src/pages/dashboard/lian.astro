---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

interface Env {
  LINE_HARNESS_URL: string;
  LINE_HARNESS_API_KEY: string;
}

const env = Astro.locals.runtime?.env as Env | undefined;
const baseUrl = env?.LINE_HARNESS_URL ?? 'https://line-crm-worker.takraw501.workers.dev';
const apiKey = env?.LINE_HARNESS_API_KEY ?? '';

let accounts: any[] = [];
let friends: any[] = [];
let friendTotal = 0;
let error = '';

try {
  const [accRes, friendRes] = await Promise.all([
    fetch(`${baseUrl}/api/line-accounts`, { headers: { Authorization: `Bearer ${apiKey}` } }),
    fetch(`${baseUrl}/api/friends?limit=10`, { headers: { Authorization: `Bearer ${apiKey}` } }),
  ]);
  const accJson = await accRes.json() as any;
  const friendJson = await friendRes.json() as any;
  accounts = accJson.data ?? [];
  friends = friendJson.data ?? [];
  friendTotal = friendJson.total ?? friends.length;
} catch (e) {
  error = String(e);
}
---
<DashboardLayout title="リアン">
  <style>
    .stat-row { display: flex; gap: 12px; margin-bottom: 24px; }
    .stat-card {
      flex: 1;
      background: #1A1612;
      border: 1px solid #2E2822;
      padding: 16px;
      text-align: center;
    }
    .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; color: #C9A96E; }
    .stat-label { font-size: 0.75rem; color: #7A6F5F; margin-top: 4px; }
    .section { margin-bottom: 28px; }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      font-weight: 300;
      color: #8B7355;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 12px;
      padding-bottom: 8px;
      border-bottom: 1px solid #2E2822;
    }
    .account-card {
      background: #1A1612;
      border: 1px solid #2E2822;
      padding: 14px 16px;
      margin-bottom: 8px;
    }
    .account-name { font-size: 0.9rem; color: #D4C5A9; }
    .account-meta { font-size: 0.75rem; color: #7A6F5F; margin-top: 4px; }
    .friend-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid #2E2822;
      font-size: 0.85rem;
    }
    .friend-row:last-child { border-bottom: none; }
    .friend-name { color: #D4C5A9; font-size: 0.875rem; }
    .friend-meta { font-size: 0.75rem; color: #7A6F5F; }
    .error { color: #E85D4A; font-size: 0.85rem; padding: 12px 16px; background: rgba(232,92,82,0.08); border: 1px solid rgba(232,92,82,0.2); margin-bottom: 20px; }
    .empty { color: #7A6F5F; font-size: 0.875rem; }
    .section-link {
      display: block;
      text-align: center;
      margin-top: 24px;
      color: #7A6F5F;
      font-size: 0.82rem;
      text-decoration: none;
      border: 1px solid #2E2822;
      padding: 12px;
      transition: color 0.2s, border-color 0.2s;
      font-family: 'Zen Kaku Gothic New', sans-serif;
    }
    .section-link:hover { color: #D4C5A9; border-color: #8B7355; }
    .friends-list {
      background: #1A1612;
      border: 1px solid #2E2822;
      padding: 0 16px;
    }
  </style>

  {error && <p class="error">{error}</p>}

  <div class="stat-row">
    <div class="stat-card">
      <div class="stat-num">{friendTotal}</div>
      <div class="stat-label">友だち総数</div>
    </div>
    <div class="stat-card">
      <div class="stat-num">{accounts.length}</div>
      <div class="stat-label">LINEアカウント</div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">LINEアカウント</div>
    {accounts.length === 0 && <p class="empty">未登録</p>}
    {accounts.map((a: any) => (
      <div class="account-card">
        <div class="account-name">{a.name ?? a.channelId}</div>
        <div class="account-meta">Channel ID: {a.channelId}</div>
      </div>
    ))}
  </div>

  <div class="section">
    <div class="section-title">最近の友だち（最新10件）</div>
    {friends.length === 0 && <p class="empty">まだ友だちがいません</p>}
    {friends.length > 0 && (
      <div class="friends-list">
        {friends.map((f: any) => (
          <div class="friend-row">
            <div>
              <div class="friend-name">{f.displayName ?? f.lineUserId}</div>
              <div class="friend-meta">{f.lineUserId}</div>
            </div>
            <div class="friend-meta">{f.createdAt ? new Date(f.createdAt).toLocaleDateString('ja-JP') : ''}</div>
          </div>
        ))}
      </div>
    )}
  </div>

  <a href="https://line-harness-admin-bwj.pages.dev" target="_blank" rel="noopener" class="section-link">
    LINE Harness 管理画面を開く →
  </a>
</DashboardLayout>
